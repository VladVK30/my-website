```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
dist/
build/
target/

# Dependencies
.venv/
venv/
node_modules/
.julia/
zig-cache/
.deps/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Package management
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# Python specific
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/
*.egg-info/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
*.ear
target/
.gradle/

# C/C++ specific
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib
*.exe

# Go specific
*.o
*.a
*.so
*.exe
*.test
*.prof
vendor/

# Ruby specific
*.gem
*.rbc
.bundle/
vendor/bundle/
vendor/cache/
vendor/gems/
vendor/ruby/

# Rust specific
target/
Cargo.lock

# PHP specific
vendor/

# .NET specific
bin/
obj/
*.sln
*.csproj.user

# Backup files
*~
\#*\#
*.bak
*.orig
*.rej
*.~*
```